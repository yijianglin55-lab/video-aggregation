# =============================================
# 影视聚合网站 - 环境变量配置
# =============================================

# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=video_aggregation

# Session配置（必须修改为随机字符串）
SESSION_SECRET=your-random-secret-key-here
SESSION_MAX_AGE=86400000

# =============================================
# 爬虫配置
# =============================================
CRAWLER_TIMEOUT=15000
CRAWLER_RETRY_COUNT=3
CRAWLER_RETRY_DELAY=1000
CRAWLER_CONCURRENT_LIMIT=3

# =============================================
# 代理IP配置（防封禁）
# =============================================
# 是否启用代理
PROXY_ENABLED=false

# 代理列表（格式：host:port 或 host:port:username:password）
# 多个代理用逗号分隔
# 示例: PROXY_LIST=127.0.0.1:7890,proxy1.com:8080:user:pass
PROXY_LIST=

# 单独代理配置（如果不使用PROXY_LIST）
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# =============================================
# 网站配置
# =============================================
SITE_NAME=鲁王影视
SITE_DESCRIPTION=高清影视资源聚合平台
SITE_KEYWORDS=电影,电视剧,综艺,动漫,高清,在线观看

# =============================================
# 管理员配置
# =============================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com