<!-- 系统监控页面模板 -->

<h3 class="mb-4">
  <i class="bi bi-graph-up me-2"></i>系统监控
</h3>

<div class="row">
  <!-- 服务器信息 -->
  <div class="col-md-6 mb-4">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">服务器信息</h5>
      </div>
      <div class="card-body">
        <ul class="list-unstyled mb-0">
          <li class="mb-2 d-flex justify-content-between">
            <span class="text-muted">运行时间</span>
            <span><%= Math.floor(stats.uptime / 3600) %> 小时 <%= Math.floor((stats.uptime % 3600) / 60) %> 分钟</span>
          </li>
          <li class="mb-2 d-flex justify-content-between">
            <span class="text-muted">Node.js版本</span>
            <span><%= process.version %></span>
          </li>
          <li class="mb-2 d-flex justify-content-between">
            <span class="text-muted">操作系统</span>
            <span><%= process.platform %> <%= process.arch %></span>
          </li>
          <li class="d-flex justify-content-between">
            <span class="text-muted">CPU使用率</span>
            <span><%= typeof stats.cpu !== 'undefined' ? (stats.cpu.user / 1000000).toFixed(2) + '%' : 'N/A' %></span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- 内存信息 -->
  <div class="col-md-6 mb-4">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">内存使用</h5>
      </div>
      <div class="card-body">
        <ul class="list-unstyled mb-0">
          <li class="mb-2 d-flex justify-content-between">
            <span class="text-muted">总内存</span>
            <span><%= (stats.memory.heapTotal / 1024 / 1024).toFixed(2) %> MB</span>
          </li>
          <li class="mb-2 d-flex justify-content-between">
            <span class="text-muted">已使用</span>
            <span><%= (stats.memory.heapUsed / 1024 / 1024).toFixed(2) %> MB</span>
          </li>
          <li class="mb-2 d-flex justify-content-between">
            <span class="text-muted">使用率</span>
            <span><%= ((stats.memory.heapUsed / stats.memory.heapTotal) * 100).toFixed(2) %>%</span>
          </li>
          <li class="d-flex justify-content-between">
            <span class="text-muted">外部内存</span>
            <span><%= (stats.memory.external / 1024 / 1024).toFixed(2) %> MB</span>
          </li>
        </ul>

        <!-- 内存使用进度条 -->
        <div class="progress mt-3" style="height: 20px;">
          <div class="progress-bar <%= (stats.memory.heapUsed / stats.memory.heapTotal) > 0.8 ? 'bg-danger' : 'bg-success' %>"
               style="width: <%= ((stats.memory.heapUsed / stats.memory.heapTotal) * 100).toFixed(2) %>%">
            <%= ((stats.memory.heapUsed / stats.memory.heapTotal) * 100).toFixed(2) %>%
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 刷新按钮 -->
<div class="text-center">
  <button class="btn btn-primary" onclick="location.reload()">
    <i class="bi bi-arrow-clockwise me-1"></i>刷新数据
  </button>
</div>