<!-- 用户管理页面模板 -->

<div class="admin-content">
  <div class="d-flex align-items-center justify-content-between mb-4 fade-in-up">
    <h3 class="mb-0 fw-bold">用户管理</h3>
  </div>

  <!-- 搜索框 -->
  <div class="admin-form mb-4 fade-in-up" style="animation-delay: 0.1s">
    <form action="/admin/users" method="GET" class="d-flex gap-2">
      <input type="text" class="form-control" name="keyword" value="<%= keyword %>" placeholder="搜索用户名或邮箱">
      <button type="submit" class="btn btn-primary rounded-pill px-4">
        <i class="bi bi-search me-1"></i>搜索
      </button>
    </form>
  </div>

  <!-- 用户列表 -->
  <div class="admin-table fade-in-up" style="animation-delay: 0.2s">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th>ID</th>
            <th>用户名</th>
            <th>邮箱</th>
            <th>角色</th>
            <th>状态</th>
            <th>注册时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% if (typeof users !== 'undefined' && users.length > 0) { %>
            <% users.forEach(u => { %>
              <tr>
                <td><%= u.id %></td>
                <td><%= u.username %></td>
                <td><%= u.email %></td>
                <td>
                  <span class="badge <%= u.role === 'admin' ? 'bg-danger' : 'bg-secondary' %>">
                    <%= u.role === 'admin' ? '管理员' : '用户' %>
                  </span>
                </td>
                <td>
                  <span class="badge <%= u.status === 'active' ? 'bg-success' : 'bg-warning' %> status-badge">
                    <%= u.status === 'active' ? '正常' : '禁用' %>
                  </span>
                </td>
                <td><%= new Date(u.created_at).toLocaleDateString('zh-CN') %></td>
                <td>
                  <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-warning toggle-user-btn"
                            data-user-id="<%= u.id %>"
                            <%= u.role === 'admin' ? 'disabled' : '' %>>
                      <%= u.status === 'active' ? '禁用' : '启用' %>
                    </button>
                    <button class="btn btn-outline-danger delete-user-btn"
                            data-user-id="<%= u.id %>"
                            data-username="<%= u.username %>"
                            <%= u.role === 'admin' ? 'disabled' : '' %>>
                      删除
                    </button>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="text-center py-4 text-secondary">暂无用户数据</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- 分页 -->
  <% if (typeof pagination !== 'undefined' && pagination.total > 1) { %>
    <nav class="mt-4 fade-in-up">
      <ul class="pagination justify-content-center">
        <li class="page-item <%= !pagination.hasPrev ? 'disabled' : '' %>">
          <a class="page-link rounded-pill" href="/admin/users?page=<%= pagination.current - 1 %>&keyword=<%= keyword %>">上一页</a>
        </li>
        <% for (let i = 1; i <= pagination.total; i++) { %>
          <li class="page-item <%= i === pagination.current ? 'active' : '' %>">
            <a class="page-link rounded-pill" href="/admin/users?page=<%= i %>&keyword=<%= keyword %>"><%= i %></a>
          </li>
        <% } %>
        <li class="page-item <%= !pagination.hasNext ? 'disabled' : '' %>">
          <a class="page-link rounded-pill" href="/admin/users?page=<%= pagination.current + 1 %>&keyword=<%= keyword %>">下一页</a>
        </li>
      </ul>
    </nav>
  <% } %>
</div>