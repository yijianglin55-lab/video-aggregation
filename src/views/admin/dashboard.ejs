<!-- 管理后台控制台模板 -->

<div class="admin-content">
  <div class="d-flex align-items-center justify-content-between mb-4 fade-in-up">
    <h3 class="mb-0 fw-bold">控制台</h3>
    <span class="text-secondary"><%= new Date().toLocaleDateString('zh-CN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></span>
  </div>

  <!-- 统计卡片 -->
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="admin-stat-card fade-in-up" style="animation-delay: 0.1s">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <div class="stat-icon bg-primary">
            <i class="bi bi-people"></i>
          </div>
          <span class="badge bg-primary">用户</span>
        </div>
        <h3><%= typeof stats !== 'undefined' ? stats.userCount : 0 %></h3>
        <p>注册用户</p>
      </div>
    </div>
    <div class="col-md-3">
      <div class="admin-stat-card fade-in-up" style="animation-delay: 0.2s">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <div class="stat-icon bg-success">
            <i class="bi bi-person-check"></i>
          </div>
          <span class="badge bg-success">在线</span>
        </div>
        <h3><%= typeof stats !== 'undefined' ? stats.onlineUsers : 0 %></h3>
        <p>在线用户</p>
      </div>
    </div>
    <div class="col-md-3">
      <div class="admin-stat-card fade-in-up" style="animation-delay: 0.3s">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <div class="stat-icon bg-warning">
            <i class="bi bi-graph-up"></i>
          </div>
          <span class="badge bg-warning">请求</span>
        </div>
        <h3><%= typeof stats !== 'undefined' ? stats.requestCount : 0 %></h3>
        <p>今日请求</p>
      </div>
    </div>
    <div class="col-md-3">
      <div class="admin-stat-card fade-in-up" style="animation-delay: 0.4s">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <div class="stat-icon bg-danger">
            <i class="bi bi-exclamation-triangle"></i>
          </div>
          <span class="badge bg-danger">错误</span>
        </div>
        <h3><%= typeof stats !== 'undefined' ? stats.errorCount : 0 %></h3>
        <p>错误日志</p>
      </div>
    </div>
  </div>

  <!-- 快捷操作 -->
  <div class="row g-3">
    <div class="col-md-6">
      <div class="admin-form fade-in-up" style="animation-delay: 0.5s">
        <h5 class="mb-3 fw-bold">快捷操作</h5>
        <div class="d-flex flex-wrap gap-2">
          <a href="/admin/users" class="btn btn-outline-primary rounded-pill">
            <i class="bi bi-people me-1"></i>用户管理
          </a>
          <a href="/admin/settings" class="btn btn-outline-secondary rounded-pill">
            <i class="bi bi-gear me-1"></i>站点配置
          </a>
          <a href="/" target="_blank" class="btn btn-outline-info rounded-pill">
            <i class="bi bi-box-arrow-up-right me-1"></i>访问前台
          </a>
        </div>
      </div>
    </div>
    <div class="col-md-6">
      <div class="admin-form fade-in-up" style="animation-delay: 0.6s">
        <h5 class="mb-3 fw-bold">系统信息</h5>
        <ul class="list-unstyled mb-0">
          <li class="d-flex justify-content-between mb-2">
            <span class="text-secondary">Node.js</span>
            <span><%= process.version %></span>
          </li>
          <li class="d-flex justify-content-between mb-2">
            <span class="text-secondary">环境</span>
            <span><%= process.env.NODE_ENV || 'development' %></span>
          </li>
          <li class="d-flex justify-content-between">
            <span class="text-secondary">平台</span>
            <span><%= process.platform %></span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</div>