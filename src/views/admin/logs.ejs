<!-- 错误日志页面模板 -->

<h3 class="mb-4">
  <i class="bi bi-journal-text me-2"></i>错误日志
</h3>

<div class="card">
  <div class="card-body">
    <% if (typeof logs !== 'undefined' && logs.length > 0) { %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>时间</th>
              <th>级别</th>
              <th>消息</th>
              <th>堆栈</th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach(log => { %>
              <tr>
                <td><%= new Date(log.timestamp).toLocaleString('zh-CN') %></td>
                <td>
                  <span class="badge <%= log.level === 'error' ? 'bg-danger' : log.level === 'warn' ? 'bg-warning' : 'bg-info' %>">
                    <%= log.level %>
                  </span>
                </td>
                <td><%= log.message %></td>
                <td>
                  <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#stack-<%= log.id %>">
                    查看
                  </button>
                  <div class="collapse mt-2" id="stack-<%= log.id %>">
                    <pre class="bg-light p-2 rounded" style="max-height: 200px; overflow: auto;"><%= log.stack %></pre>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="text-center py-5">
        <i class="bi bi-journal-check display-1 text-muted"></i>
        <p class="mt-3 text-muted">暂无错误日志</p>
      </div>
    <% } %>
  </div>
</div>