<!-- 个人资料页面模板 -->

<div class="user-page">
  <div class="container py-4">
    <!-- 返回按钮 -->
    <a href="/user" class="back-link fade-in-up">
      <i class="bi bi-arrow-left me-2"></i>返回用户中心
    </a>

    <div class="row justify-content-center">
      <div class="col-lg-8">
        <!-- 个人资料卡片 -->
        <div class="profile-card fade-in-up" style="animation-delay: 0.1s">
          <div class="profile-header">
            <div class="profile-avatar">
              <i class="bi bi-person-fill"></i>
            </div>
            <h4><%= user.username %></h4>
          </div>

          <form action="/user/profile" method="POST" class="profile-form">
            <!-- 用户名（只读） -->
            <div class="mb-3">
              <label class="form-label">用户名</label>
              <input type="text" class="form-control" value="<%= user.username %>" disabled>
              <small class="text-secondary">用户名不可修改</small>
            </div>

            <!-- 邮箱 -->
            <div class="mb-3">
              <label for="email" class="form-label">邮箱</label>
              <input type="email" class="form-control" id="email" name="email" value="<%= user.email %>" required>
            </div>

            <hr class="my-4">

            <h5 class="mb-3">修改密码</h5>
            <p class="text-secondary mb-3">如果不修改密码，请留空。</p>

            <!-- 当前密码 -->
            <div class="mb-3">
              <label for="currentPassword" class="form-label">当前密码</label>
              <input type="password" class="form-control" id="currentPassword" name="currentPassword">
            </div>

            <!-- 新密码 -->
            <div class="mb-3">
              <label for="newPassword" class="form-label">新密码</label>
              <input type="password" class="form-control" id="newPassword" name="newPassword" minlength="6">
            </div>

            <!-- 确认新密码 -->
            <div class="mb-4">
              <label for="confirmNewPassword" class="form-label">确认新密码</label>
              <input type="password" class="form-control" id="confirmNewPassword" name="confirmNewPassword" minlength="6">
            </div>

            <div class="d-flex justify-content-end gap-2">
              <a href="/user" class="btn btn-outline-secondary rounded-pill px-4">取消</a>
              <button type="submit" class="btn btn-primary rounded-pill px-4">
                <i class="bi bi-check-lg me-1"></i>保存修改
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>