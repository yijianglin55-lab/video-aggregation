<!DOCTYPE html>
<html lang="zh-CN" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= typeof meta !== 'undefined' && meta.description ? meta.description : '' %>">
  <meta name="keywords" content="<%= typeof meta !== 'undefined' && meta.keywords ? meta.keywords : '' %>">
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>X影视</title>

  <!-- Bootstrap5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">
  <!-- 自定义CSS -->
  <link href="/css/style.css" rel="stylesheet">
  <link href="/css/player.css" rel="stylesheet">
  <link href="/css/responsive.css" rel="stylesheet">
</head>
<body class="bg-dark">
  <!-- 全局加载动画 -->
  <div id="globalLoading" class="global-loading">
    <div class="loading-spinner-wrapper">
      <div class="loading-spinner"></div>
      <p class="loading-text">加载中...</p>
    </div>
  </div>

  <!-- 播放页导航 -->
  <nav class="player-navbar">
    <div class="container">
      <div class="player-navbar-content">
        <!-- 返回按钮 -->
        <a href="/" class="player-nav-btn back-btn">
          <i class="bi bi-arrow-left"></i>
          <span>首页</span>
        </a>

        <!-- Logo -->
        <a href="/" class="player-logo">
          <span class="logo-x-sm">X</span>
          <span class="site-name-sm">影视</span>
        </a>

        <!-- 标题 -->
        <div class="player-title">
          <%= typeof video !== 'undefined' && video.title ? video.title : '' %>
        </div>

        <!-- 详情页按钮 -->
        <% if (typeof video !== 'undefined' && video) { %>
          <a href="/detail/<%= video.type %>/<%= video.id %>" class="player-nav-btn detail-btn">
            <i class="bi bi-info-circle"></i>
            <span>详情</span>
          </a>
        <% } %>
      </div>
    </div>
  </nav>

  <!-- 播放器内容 -->
  <main>
    <%- body %>
  </main>

  <!-- Bootstrap5 JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <!-- 自定义JS -->
  <script src="/js/main.js"></script>
  <script src="/js/player.js"></script>

  <!-- 全局加载动画控制 -->
  <script>
    var loadingTimer = null;
    var loadingTextTimer = null;

    function showLoading() {
      var el = document.getElementById('globalLoading');
      var textEl = el.querySelector('.loading-text');

      el.classList.add('show');
      document.body.style.overflow = 'hidden';
      textEl.textContent = '加载中...';

      loadingTextTimer = setTimeout(function() {
        textEl.textContent = '即将加载完成...';
      }, 5000);

      loadingTimer = setTimeout(hideLoading, 20000);
    }

    function hideLoading() {
      var el = document.getElementById('globalLoading');
      el.classList.remove('show');
      document.body.style.overflow = '';

      if (loadingTimer) {
        clearTimeout(loadingTimer);
        loadingTimer = null;
      }
      if (loadingTextTimer) {
        clearTimeout(loadingTextTimer);
        loadingTextTimer = null;
      }
    }

    document.addEventListener('click', function(e) {
      var link = e.target.closest('a');
      if (!link) return;
      var href = link.getAttribute('href');
      if (!href || href === '#' || href.startsWith('javascript:') || href.startsWith('mailto:')) return;
      if (link.target === '_blank') return;
      showLoading();
      link.classList.add('loading-state');
    });

    window.addEventListener('load', hideLoading);
    window.addEventListener('pageshow', hideLoading);
    document.addEventListener('DOMContentLoaded', hideLoading);
  </script>
</body>
</html>