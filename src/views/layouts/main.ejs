<!DOCTYPE html>
<html lang="zh-CN" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= typeof meta !== 'undefined' && meta.description ? meta.description : siteConfig.description %>">
  <meta name="keywords" content="<%= typeof meta !== 'undefined' && meta.keywords ? meta.keywords : siteConfig.keywords %>">
  <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %><%= siteConfig.name %></title>

  <!-- Bootstrap5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css" rel="stylesheet">
  <!-- 自定义CSS -->
  <link href="/css/style.css" rel="stylesheet">
  <link href="/css/responsive.css" rel="stylesheet">

  <!-- 预加载关键资源 -->
  <link rel="preconnect" href="https://fdzys.net">
  <link rel="dns-prefetch" href="https://fdzys.net">
</head>
<body>
  <!-- 导航栏 -->
  <%- include('../partials/navbar') %>

  <!-- 全局加载动画 -->
  <%- include('../partials/loading') %>

  <!-- 主要内容 -->
  <main class="min-vh-100">
    <%- body %>
  </main>

  <!-- 页脚 -->
  <%- include('../partials/footer') %>

  <!-- Bootstrap5 JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <!-- 自定义JS -->
  <script src="/js/main.js"></script>

  <!-- 全局加载动画控制 -->
  <script>
    // 显示加载动画
    function showLoading() {
      document.getElementById('globalLoading').classList.add('show');
      document.body.style.overflow = 'hidden';
    }

    // 隐藏加载动画
    function hideLoading() {
      document.getElementById('globalLoading').classList.remove('show');
      document.body.style.overflow = '';
    }

    // 监听所有链接点击
    document.addEventListener('click', function(e) {
      var link = e.target.closest('a');
      if (!link) return;

      var href = link.getAttribute('href');
      if (!href || href === '#' || href.startsWith('javascript:') || href.startsWith('mailto:')) return;

      // 排除新窗口打开
      if (link.target === '_blank') return;

      // 排除锚点链接
      if (href.startsWith('#')) return;

      // 显示加载动画
      showLoading();

      // 防止重复点击
      link.classList.add('loading-state');

      // 超时隐藏（防止卡住）
      setTimeout(hideLoading, 10000);
    });

    // 监听表单提交
    document.addEventListener('submit', function(e) {
      var form = e.target;
      var submitBtn = form.querySelector('button[type="submit"], input[type="submit"]');

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.classList.add('loading-state');
      }

      showLoading();

      // 超时隐藏
      setTimeout(hideLoading, 10000);
    });

    // 页面加载完成后隐藏
    window.addEventListener('load', hideLoading);

    // 导航栏滚动效果
    window.addEventListener('scroll', function() {
      var navbar = document.querySelector('.navbar');
      if (window.scrollY > 50) {
        navbar.classList.add('scrolled');
      } else {
        navbar.classList.remove('scrolled');
      }
    });
  </script>
</body>
</html>