<!-- 搜索结果页模板 -->

<div class="container py-4">
  <!-- 搜索框 -->
  <div class="row justify-content-center mb-5">
    <div class="col-lg-8">
      <form action="/search" method="GET" class="search-box">
        <div class="input-group input-group-lg">
          <input type="text" class="form-control" name="wd" value="<%= keyword %>" placeholder="搜索电影、电视剧、综艺、动漫..." required>
          <button class="btn btn-primary px-4" type="submit">
            <i class="bi bi-search me-2"></i>搜索
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- 搜索结果 -->
  <% if (keyword) { %>
    <div class="d-flex align-items-center mb-4">
      <div class="bg-info bg-gradient rounded-3 p-2 me-3">
        <i class="bi bi-search text-white fs-4"></i>
      </div>
      <div>
        <h3 class="mb-0 fw-bold">搜索结果</h3>
        <p class="text-secondary mb-0">关键词：<%= keyword %></p>
      </div>
    </div>

    <% if (typeof results !== 'undefined' && results.length > 0) { %>
      <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 row-cols-xl-6 g-3">
        <% results.forEach((video, index) => { %>
          <div class="col" style="animation-delay: <%= index * 0.05 %>s">
            <%- include('../partials/video-card', { video: video }) %>
          </div>
        <% }) %>
      </div>

      <!-- 分页 -->
      <% if (typeof pagination !== 'undefined' && pagination.total > 1) { %>
        <nav class="mt-5" aria-label="分页导航">
          <ul class="pagination justify-content-center">
            <li class="page-item <%= !pagination.hasPrev ? 'disabled' : '' %>">
              <a class="page-link rounded-pill" href="/search?wd=<%= keyword %>&page=<%= pagination.current - 1 %>">
                <i class="bi bi-chevron-left me-1"></i>上一页
              </a>
            </li>
            <% pagination.pages.forEach(page => { %>
              <li class="page-item <%= page.page === pagination.current ? 'active' : '' %>">
                <a class="page-link rounded-pill" href="/search?wd=<%= keyword %>&page=<%= page.page %>"><%= page.page %></a>
              </li>
            <% }) %>
            <li class="page-item <%= !pagination.hasNext ? 'disabled' : '' %>">
              <a class="page-link rounded-pill" href="/search?wd=<%= keyword %>&page=<%= pagination.current + 1 %>">
                下一页<i class="bi bi-chevron-right ms-1"></i>
              </a>
            </li>
          </ul>
        </nav>
      <% } %>
    <% } else { %>
      <div class="empty-state">
        <i class="bi bi-search display-1"></i>
        <h4 class="mt-3">未找到相关影片</h4>
        <p class="text-secondary">请尝试其他关键词</p>
      </div>
    <% } %>
  <% } else { %>
    <div class="empty-state">
      <i class="bi bi-search display-1"></i>
      <h4 class="mt-3">请输入搜索关键词</h4>
      <p class="text-secondary">搜索你想看的电影、电视剧、综艺、动漫</p>
    </div>
  <% } %>
</div>