<!-- 详情页模板 -->

<% if (typeof video !== 'undefined' && video) { %>
<div class="container py-4">
  <!-- 面包屑导航 -->
  <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/" class="text-secondary">首页</a></li>
      <li class="breadcrumb-item"><a href="/<%= video.type %>" class="text-secondary"><%= video.type === 'movie' ? '电影' : video.type === 'tv' ? '电视剧' : video.type === 'zongyi' ? '综艺' : '动漫' %></a></li>
      <li class="breadcrumb-item active"><%= video.title %></li>
    </ol>
  </nav>

  <div class="row g-4">
    <!-- 封面 -->
    <div class="col-lg-3 col-md-4">
      <div class="detail-cover sticky-md-top" style="top: 80px;">
        <img src="<%= video.cover || '/img/default-cover.jpg' %>" alt="<%= video.title %>" class="img-fluid rounded-4 shadow-lg">
      </div>
    </div>

    <!-- 详细信息 -->
    <div class="col-lg-9 col-md-8">
      <div class="card bg-transparent border-0">
        <div class="card-body p-0">
          <h1 class="fw-bold mb-3" style="font-size: 1.75rem;"><%= video.title %></h1>

          <!-- 标签 -->
          <div class="d-flex flex-wrap gap-2 mb-4">
            <% if (video.score && video.score !== '0.0') { %>
              <span class="badge bg-warning text-dark fs-6">
                <i class="bi bi-star-fill me-1"></i><%= video.score %>
              </span>
            <% } %>
            <% if (video.year) { %>
              <span class="badge bg-secondary fs-6"><%= video.year %></span>
            <% } %>
            <% if (video.type) { %>
              <span class="badge bg-info fs-6">
                <%= video.type === 'movie' ? '电影' : video.type === 'tv' ? '电视剧' : video.type === 'zongyi' ? '综艺' : '动漫' %>
              </span>
            <% } %>
          </div>

          <!-- 信息表格 -->
          <div class="table-responsive mb-4">
            <table class="table table-borderless mb-0 detail-info-table">
              <tbody>
                <% if (video.genre) { %>
                  <tr>
                    <td class="text-secondary" style="width: 80px;">类型</td>
                    <td class="text-white"><%= video.genre %></td>
                  </tr>
                <% } %>
                <% if (video.area) { %>
                  <tr>
                    <td class="text-secondary">地区</td>
                    <td class="text-white"><%= video.area %></td>
                  </tr>
                <% } %>
                <% if (video.director) { %>
                  <tr>
                    <td class="text-secondary">导演</td>
                    <td class="text-white"><%= video.director %></td>
                  </tr>
                <% } %>
                <% if (video.actors) { %>
                  <tr>
                    <td class="text-secondary">主演</td>
                    <td class="text-white"><%= video.actors %></td>
                  </tr>
                <% } %>
                <% if (video.updateTime) { %>
                  <tr>
                    <td class="text-secondary">更新</td>
                    <td class="text-white"><%= video.updateTime %></td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>

          <!-- 操作按钮 -->
          <div class="d-flex flex-wrap gap-3 mb-4">
            <a href="/play/<%= video.type %>/<%= video.id %>" class="btn btn-primary btn-lg rounded-pill px-4 play-btn" id="playBtn">
              <i class="bi bi-play-fill me-2"></i>立即播放
            </a>
            <button class="btn btn-outline-danger btn-lg rounded-pill px-4 favorite-btn" data-type="<%= video.type %>" data-id="<%= video.id %>" data-name="<%= video.title %>">
              <i class="bi bi-heart me-2"></i>收藏
            </button>
          </div>
        </div>
      </div>

      <!-- 简介 -->
      <% if (video.description) { %>
        <div class="card bg-secondary bg-opacity-25 border-0 rounded-4 mb-4">
          <div class="card-header bg-transparent border-0">
            <h5 class="mb-0 fw-bold"><i class="bi bi-card-text me-2"></i>剧情简介</h5>
          </div>
          <div class="card-body">
            <p class="mb-0 text-secondary" style="line-height: 1.8;"><%= video.description %></p>
          </div>
        </div>
      <% } %>

      <!-- 播放源 -->
      <% if (video.playSources && video.playSources.length > 0) { %>
        <%
          // 官方源列表
          const officialSources = ['qiyi', 'bilibili', '优酷云', 'mgtv', '企鹅云'];
        %>
        <div class="card bg-secondary bg-opacity-25 border-0 rounded-4 mb-4">
          <div class="card-header bg-transparent border-0">
            <h5 class="mb-0 fw-bold">
              <i class="bi bi-broadcast me-2"></i>播放源
            </h5>
          </div>
          <div class="card-body">
            <div class="source-tabs-detail">
              <% video.playSources.forEach((source, index) => { %>
                <%
                  const isOfficial = officialSources.some(s =>
                    source.name.toLowerCase().includes(s.toLowerCase())
                  );
                %>
                <a href="/play/<%= video.type %>/<%= video.id %>?sid=<%= source.href.replace('#playlist', '') %>"
                   class="source-tab-detail <%= isOfficial ? 'official' : '' %>">
                  <%= source.name %>
                </a>
              <% }) %>
            </div>
          </div>
        </div>
      <% } %>

      <!-- 剧集列表 -->
      <% if (video.episodes && video.episodes.length > 0) { %>
        <div class="card bg-secondary bg-opacity-25 border-0 rounded-4 mb-4">
          <div class="card-header bg-transparent border-0">
            <h5 class="mb-0 fw-bold"><i class="bi bi-collection-play me-2"></i>选集</h5>
          </div>
          <div class="card-body">
            <div class="row row-cols-4 row-cols-md-6 row-cols-lg-8 g-2">
              <% video.episodes.forEach(episode => { %>
                <div class="col">
                  <a href="/play/<%= video.type %>/<%= video.id %>/<%= episode.name %>"
                     class="btn btn-outline-secondary w-100 rounded-pill text-truncate">
                    <%= episode.name %>
                  </a>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>
<% } else { %>
  <div class="container py-5">
    <div class="text-center">
      <i class="bi bi-exclamation-circle display-1 text-muted"></i>
      <h3 class="mt-3">影片信息加载失败</h3>
      <p class="text-muted">请稍后重试或返回首页</p>
      <a href="/" class="btn btn-primary rounded-pill px-4">
        <i class="bi bi-house-door me-2"></i>返回首页
      </a>
    </div>
  </div>
<% } %>

<!-- 详情页脚本 -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  // 播放按钮加载状态
  var playBtn = document.getElementById('playBtn');
  if (playBtn) {
    playBtn.addEventListener('click', function(e) {
      this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>加载中...';
      this.classList.add('disabled');
    });
  }

  // 收藏功能
  document.querySelectorAll('.favorite-btn').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var type = this.dataset.type;
      var id = this.dataset.id;
      var name = this.dataset.name;

      try {
        var response = await fetch('/api/favorite', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: type, id: id, name: name })
        });

        var result = await response.json();

        if (result.success) {
          this.classList.remove('btn-outline-danger');
          this.classList.add('btn-danger');
          this.innerHTML = '<i class="bi bi-heart-fill me-2"></i>已收藏';
        } else {
          alert(result.message || '操作失败');
        }
      } catch (error) {
        alert('请先登录');
        window.location.href = '/auth/login';
      }
    });
  });
});
</script>