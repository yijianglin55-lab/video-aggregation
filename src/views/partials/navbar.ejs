<!-- 导航栏 -->
<nav class="navbar navbar-expand-lg navbar-dark sticky-top">
  <div class="container">
    <!-- 网站Logo -->
    <a class="navbar-brand d-flex align-items-center" href="/">
      <div class="logo-icon">
        <span class="logo-text">鲁王</span>
      </div>
      <span class="site-name">影视</span>
    </a>

    <!-- 移动端切换按钮 -->
    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- 导航链接 -->
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto ms-3">
        <li class="nav-item">
          <a class="nav-link <%= currentPath === '/' ? 'active' : '' %>" href="/">
            <i class="bi bi-house-door me-1"></i>首页
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/movie') ? 'active' : '' %>" href="/movie">
            <i class="bi bi-camera-reels me-1"></i>电影
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/tv') ? 'active' : '' %>" href="/tv">
            <i class="bi bi-tv me-1"></i>电视剧
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/zongyi') ? 'active' : '' %>" href="/zongyi">
            <i class="bi bi-mic me-1"></i>综艺
          </a>
        </li>
        <li class="nav-item">
          <a class="nav-link <%= currentPath.startsWith('/dongman') ? 'active' : '' %>" href="/dongman">
            <i class="bi bi-palette me-1"></i>动漫
          </a>
        </li>
      </ul>

      <!-- 搜索表单 -->
      <form class="d-flex me-3 search-box" action="/search" method="GET">
        <div class="input-group">
          <input type="text" class="form-control" name="wd" placeholder="搜索影片..." required>
          <button class="btn btn-primary" type="submit">
            <i class="bi bi-search"></i>
          </button>
        </div>
      </form>

      <!-- 用户菜单 -->
      <ul class="navbar-nav">
        <% if (typeof user !== 'undefined' && user) { %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown">
              <div class="bg-primary bg-gradient rounded-circle p-1 me-2">
                <i class="bi bi-person-fill text-white"></i>
              </div>
              <span><%= user.username %></span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/user"><i class="bi bi-person me-2"></i>用户中心</a></li>
              <li><a class="dropdown-item" href="/user/favorites"><i class="bi bi-heart me-2"></i>我的收藏</a></li>
              <li><a class="dropdown-item" href="/user/history"><i class="bi bi-clock-history me-2"></i>播放历史</a></li>
              <% if (user.role === 'admin' || user.role === 1) { %>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="/admin"><i class="bi bi-shield-lock me-2"></i>管理后台</a></li>
              <% } %>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item text-danger" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i>退出登录</a></li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/auth/login">登录</a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>